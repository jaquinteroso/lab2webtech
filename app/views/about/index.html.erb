<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      
      <section id="about" class="card shadow-sm p-4 mb-4">
        <h2 class="card-title text-primary">About Me</h2>
        
        <div class="text-center my-3">
          <%= image_tag "Perfil.jpg", alt: "Jorge Quinteros", class: "img-fluid rounded-circle border shadow-sm", style: "width: 180px; height: 180px; object-fit: cover;" %>
        </div>

        <ul class="list-group list-group-flush mb-3">
          <li class="list-group-item"><strong>Name:</strong> Jorge Quinteros</li>
          <li class="list-group-item"><strong>Major:</strong> Civil Engineer in Computer Science</li>
          <li class="list-group-item"><strong>Year:</strong> Third Year</li>
        </ul>

        <p class="card-text">
          I am passionate about technology and software development. I'm trying to learn various programming languages and be able to make any project I want. In my free time, I like gaming and doing outdoor activities.
        </p>
        
        <%= link_to "Check out my GitHub profile", "https://github.com/jaquinteroso", target: "_blank", class: "btn btn-dark" %>
      </section>

      <section id="skills-section" class="card shadow-sm p-4 mb-4">
        <h2 class="text-primary mb-3">Skills</h2>
        <table class="table table-hover table-striped">
          <thead class="table-dark">
            <tr>
              <th>Skill</th>
              <th>Level</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Python</td><td>Intermediate</td></tr>
            <tr><td>JavaScript</td><td>Basic</td></tr>
            <tr><td>HTML/CSS</td><td>Basic</td></tr>
            <tr><td>Git</td><td>Advanced</td></tr>
            <tr><td>English</td><td>Advanced</td></tr>
          </tbody>
        </table>
      </section>

      <section id="interactive" class="card shadow-sm p-4 mb-5">
        <h2 class="text-primary">Interaction Zone</h2>
        <p id="change-text" class="alert alert-info">This text will change when you type something below!</p>
        <div class="input-group">
          <input type="text" id="user-input" class="form-control" placeholder="Type something here...">
          <button id="action-btn" class="btn btn-primary">Update Text</button>
        </div>
      </section>

    </div>
  </div>
</div>

<script>
    const button = document.getElementById('action-btn');
    const input = document.getElementById('user-input');
    const textToChange = document.getElementById('change-text');

    button.addEventListener('click', () => {
        if (input.value !== "") {
            textToChange.innerText = input.value;
            input.value = "";
        }
    });
</script>
